# ===== คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง =====
# คำสั่ง: copy .env.example .env   (Windows)

# ---- Qwen3-VL (เสิร์ฟบน server คนละเครื่อง — ใช้ IP ของ server ห้ามใช้ 127.0.0.1) ----
# 127.0.0.1 = เครื่องตัวเอง จะวิ่งหา server ไม่เจอ ต้องใส่ IP จริงของ server
# เลือกทางใดทาง:
#   Ollama ตรงๆ : http://<SERVER_IP>:11434/v1   (server ต้องตั้ง OLLAMA_HOST=0.0.0.0:11434 ให้เครื่องนอกเข้าได้)
#   vLLM        : http://<SERVER_IP>:8000/v1
#   AnythingLLM : http://<SERVER_IP>:3001/api/v1/openai   (เปิด Developer API + ใส่ key ด้านล่าง)
# แทน <SERVER_IP> ด้วยเลขจริง เช่น 192.168.1.50
QWEN_BASE_URL=http://<SERVER_IP>:11434/v1

# ชื่อโมเดล (ตรวจด้วย: ollama list  หรือ curl <BASE_URL>/models)
#   Ollama ตัวอย่าง: qwen3-vl:4b
#   vLLM   ตัวอย่าง: Qwen/Qwen3-VL-4B-Instruct
QWEN_MODEL=qwen3-vl:4b

# local มักไม่ต้องใช้ key
QWEN_API_KEY=not-needed

# เปิด vision = 1 (Qwen3-VL มองรูปได้ ส่งรูปเข้า LLM ตรงๆ)
QWEN_VISION=1

# ---- Azure OpenAI API (โมเดลคลาวด์ เช่น gpt-5.4-mini) ----
# ซื้อผ่าน Azure → ดู endpoint/key ได้ที่ Azure Portal > Azure OpenAI > Keys and Endpoint
# AZURE_OPENAI_ENDPOINT = https://<RESOURCE_NAME>.openai.azure.com
# AZURE_OPENAI_API_KEY  = ใส่ key จริงจาก Azure Portal
# AZURE_OPENAI_API_VERSION = 2025-04-01-preview (ดูเวอร์ชันล่าสุดจาก Azure docs)
# AZURE_OPENAI_DEPLOYMENT = ชื่อ deployment ที่ตั้งไว้ใน Azure (ไม่ใช่ชื่อโมเดล)
#   ตัวอย่าง: ถ้าสร้าง deployment ชื่อ "gpt-54-mini" ใส่ค่านั้น
AZURE_OPENAI_ENDPOINT=https://<RESOURCE_NAME>.openai.azure.com
AZURE_OPENAI_API_KEY=<YOUR_AZURE_API_KEY>
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-54-mini

# ---- n8n proxy (ยิง GPT ผ่าน webhook n8n แทนเรียก Azure ตรง) ----
# n8n ถือ API key เอง → key ไม่อยู่ในแอป, คุมกลาง/log ที่ n8n ได้ (ข้อมูลยังไป Azure บริษัทเหมือนเดิม)
# ใส่แค่ URL webhook (ไม่มี secret) — n8n workflow: backend/n8n/ask_javis.json
# ตั้งค่านี้แล้ว dropdown จะมีตัวเลือก "GPT-5.4 Mini (ผ่าน n8n · ปลอดภัย)"
N8N_ASK_URL=http://<N8N_HOST>/webhook/ask_javis

# ---- Gemini (STT/TTS) — ใช้ key/บัญชี Gemini ของบริษัท ----
# key เป็นของบริษัท (คุม/จ่ายผ่านบัญชี company) -> ยิง endpoint default googleapis.com ได้ = ช่องทางบริษัท
GEMINI_API_KEY=<KEY_บริษัท>
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta   # เปลี่ยนเฉพาะถ้าบริษัทมี gateway/proxy เอง

# ---- STT remote (server แปลงเสียง) ----
# STT_ENGINE เลือกเครื่องถอดเสียง: openai(ค่าเริ่มต้น) | gemini | whisper
#   openai = gpt-4o-transcribe (เร็ว ~1.5s + แม่นกับคำถามสั้น) — ตั้งค่าที่ "OpenAI Audio" ท้ายไฟล์
#   gemini = ส่งเสียงขึ้น Gemini ถอด (ช้ากว่า); ล่ม -> ตก whisper local/mock
# STT_ENGINE=openai
# GEMINI_STT_MODEL=gemini-2.5-flash        # โมเดลถอดเสียง (audio understanding)
# ตั้ง = ส่งไฟล์เสียงไปถอดที่ STT service บน server (ดู ../stt_server/)
# ปล่อยว่าง = ถอดในเครื่อง local เองด้วย faster-whisper (ตามค่า WHISPER_* ด้านล่าง)
STT_BASE_URL=http://<SERVER_IP>:8900
# STT_TIMEOUT=1800          # วินาที (คลิปยาวใช้เวลานาน)

# ---- WhisperX / faster-whisper (ใช้ตอนถอดในเครื่อง local เท่านั้น) ----
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu          # cuda ถ้ามี GPU

# ---- Obsidian vault (ทาง A: ชี้ไป vault เดิมที่มี standard work) ----
# ระบบจะเขียนลง subfolder meetings/ และ machines/ ภายใต้ path นี้
# ตัวอย่าง: D:\FactoryVault
VAULT_PATH=D:\FactoryVault

# ---- เสียงอ่านคำตอบ JARVIS (TTS) หน้า /ask ----
# TTS_ENGINE: openai(ค่าเริ่มต้น) | gemini | windows(offline)
#   openai = gpt-4o-mini-tts (เร็ว ~2x + steerable โทน) — ตั้งค่าที่ "OpenAI Audio" ท้ายไฟล์
#   ล่ม -> fallback เสียงสังเคราะห์เบราว์เซอร์ (ในเครื่อง)
# TTS_ENGINE=openai
# -- Gemini TTS (คืน PCM 24k โค้ดห่อ WAV ให้) — ใช้ GEMINI_API_KEY/BASE_URL ด้านบน --
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE=Charon       # 1 ใน ~30 เสียง เช่น Charon/Kore/Fenrir/Orus/Puck — ลองหาที่ใกล้ JARVIS สุด
# GEMINI_TTS_TIMEOUT=60
# -- JARVIS DSP FX (DSP ในเครื่อง numpy/PyAV — ไม่ออกเน็ต): band-limit + presence + echo ห้องแคบ --
# TTS_FX=1                      # 0 = ปิด FX (คืนเสียง gemini ดิบ)
# TTS_FX_HP=120                 # highpass Hz (ตัดเบสบาง)
# TTS_FX_LP=5000                # lowpass Hz (ตัดไฮ)
# TTS_FX_PRESENCE=4.0           # gain ย่านสูง (คม/สว่าง)
# TTS_FX_PRESENCE_F=1200        # ความถี่เริ่มบูสต์
# TTS_FX_ECHO_MS=22             # echo delay ms (ห้องแคบ)
# TTS_FX_ECHO_GAIN=0.16         # ความดัง echo 0-1

# ========================================================================
# OpenAI Audio — gpt-4o-mini-tts (TTS) + gpt-4o-transcribe (STT)
#   เร็ว (<1s, streaming) + เสียงดี + steerable ; ใช้ OpenAI audio API มาตรฐาน
#   ** ใช้ key/endpoint แยกต่างหาก ** (คนละตัวกับ Gemini และคนละ deployment กับ GPT-5.4 LLM)
# ------------------------------------------------------------------------
# เปิดใช้ทีละงาน (ยังคง gemini/whisper ไว้สลับได้):
# TTS_ENGINE=openai
# STT_ENGINE=openai
#
# --- ทาง A: ผ่าน Azure OpenAI (แนะนำ — บัญชีบริษัท, compliant) ---
#   ให้ IT deploy 2 โมเดลนี้บน Azure OpenAI resource แล้วเอาค่ามาใส่
#   (อาจเป็น resource เดียวกับ GPT-5.4 = ใช้ endpoint/key เดิม, หรือคนละ resource = ใส่ค่าใหม่)
# OPENAI_AUDIO_PROVIDER=azure
# OPENAI_AUDIO_ENDPOINT=https://<RESOURCE_NAME>.openai.azure.com   # endpoint ของ resource เสียง
# OPENAI_AUDIO_API_KEY=<KEY ของ resource เสียง>                    # << key แยกที่พี่ถาม
# OPENAI_AUDIO_API_VERSION=2025-03-01-preview
# OPENAI_TTS_DEPLOYMENT=gpt-4o-mini-tts        # ชื่อ "deployment" ใน Azure (ไม่ใช่ชื่อโมเดล)
# OPENAI_STT_DEPLOYMENT=gpt-4o-transcribe
#
# --- ทาง B: OpenAI ตรง (ถ้าไม่ผ่าน Azure) ---
# OPENAI_AUDIO_PROVIDER=openai
# OPENAI_AUDIO_BASE_URL=https://api.openai.com/v1
# OPENAI_AUDIO_API_KEY=sk-...                  # << key แยกของ OpenAI
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_STT_MODEL=gpt-4o-transcribe
#
# --- เสียง + โทน (ใช้ร่วมทั้ง 2 ทาง) ---
# OPENAI_TTS_VOICE=onyx          # ชายทุ้ม; เลือก alloy/ash/echo/onyx/sage/... (ash/onyx = ทุ้มเข้ม)
# OPENAI_TTS_INSTRUCTIONS=พูดนิ่ง สุภาพ ทุ้ม มั่นใจ แบบผู้ช่วย AI (JARVIS)   # steer โทนเสียง
# OPENAI_TTS_FORMAT=wav          # wav/mp3/opus/pcm ; wav เข้ากับ JARVIS FX ได้เลย
# OPENAI_STT_LANG=th
