# ===== คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง =====
# คำสั่ง: copy .env.example .env   (Windows)

# ---- Qwen3-VL (เสิร์ฟบน server คนละเครื่อง — ใช้ IP ของ server ห้ามใช้ 127.0.0.1) ----
# 127.0.0.1 = เครื่องตัวเอง จะวิ่งหา server ไม่เจอ ต้องใส่ IP จริงของ server
# เลือกทางใดทาง:
#   Ollama ตรงๆ : http://<SERVER_IP>:11434/v1   (server ต้องตั้ง OLLAMA_HOST=0.0.0.0:11434 ให้เครื่องนอกเข้าได้)
#   vLLM        : http://<SERVER_IP>:8000/v1
#   AnythingLLM : http://<SERVER_IP>:3001/api/v1/openai   (เปิด Developer API + ใส่ key ด้านล่าง)
# แทน <SERVER_IP> ด้วยเลขจริง เช่น 192.168.1.50
QWEN_BASE_URL=http://<SERVER_IP>:11434/v1

# ชื่อโมเดล (ตรวจด้วย: ollama list  หรือ curl <BASE_URL>/models)
#   Ollama ตัวอย่าง: qwen3-vl:4b
#   vLLM   ตัวอย่าง: Qwen/Qwen3-VL-4B-Instruct
QWEN_MODEL=qwen3-vl:4b

# local มักไม่ต้องใช้ key
QWEN_API_KEY=not-needed

# เปิด vision = 1 (Qwen3-VL มองรูปได้ ส่งรูปเข้า LLM ตรงๆ)
QWEN_VISION=1

# ---- Azure OpenAI API (โมเดลคลาวด์ เช่น gpt-5.4-mini) ----
# ซื้อผ่าน Azure → ดู endpoint/key ได้ที่ Azure Portal > Azure OpenAI > Keys and Endpoint
# AZURE_OPENAI_ENDPOINT = https://<RESOURCE_NAME>.openai.azure.com
# AZURE_OPENAI_API_KEY  = ใส่ key จริงจาก Azure Portal
# AZURE_OPENAI_API_VERSION = 2025-04-01-preview (ดูเวอร์ชันล่าสุดจาก Azure docs)
# AZURE_OPENAI_DEPLOYMENT = ชื่อ deployment ที่ตั้งไว้ใน Azure (ไม่ใช่ชื่อโมเดล)
#   ตัวอย่าง: ถ้าสร้าง deployment ชื่อ "gpt-54-mini" ใส่ค่านั้น
AZURE_OPENAI_ENDPOINT=https://<RESOURCE_NAME>.openai.azure.com
AZURE_OPENAI_API_KEY=<YOUR_AZURE_API_KEY>
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-54-mini

# ---- n8n proxy (ยิง GPT ผ่าน webhook n8n แทนเรียก Azure ตรง) ----
# n8n ถือ API key เอง → key ไม่อยู่ในแอป, คุมกลาง/log ที่ n8n ได้ (ข้อมูลยังไป Azure บริษัทเหมือนเดิม)
# ใส่แค่ URL webhook (ไม่มี secret) — n8n workflow: backend/n8n/ask_javis.json
# ตั้งค่านี้แล้ว dropdown จะมีตัวเลือก "GPT-5.4 Mini (ผ่าน n8n · ปลอดภัย)"
N8N_ASK_URL=http://<N8N_HOST>/webhook/ask_javis

# ---- Gemini (Google AI Studio) — ใช้กับ STT/TTS แทน Whisper/edge ----
# key แบบ AIza... จาก aistudio.google.com/apikey (endpoint มาตรฐาน generativelanguage.googleapis.com)
# เลือกโมเดล = ใส่ชื่อโมเดลด้านล่าง (Gemini ไม่มี dropdown — โมเดลอยู่ใน URL ที่โค้ดประกอบให้)
# ตั้ง key นี้ค่าเดียว แล้วเปิดใช้ทีละงานด้วย STT_ENGINE=gemini / TTS_ENGINE=gemini
GEMINI_API_KEY=<YOUR_AIza_KEY>
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta   # เปลี่ยนเฉพาะถ้าใช้ gateway บริษัท

# ---- STT remote (server แปลงเสียง) ----
# STT_ENGINE เลือกเครื่องถอดเสียง: whisper(ค่าเริ่มต้น) | gemini
#   gemini = ส่งเสียงขึ้น Gemini ถอด (ไม่กิน GPU เครื่อง แต่ต้องเน็ต+มี GEMINI_API_KEY); ล่ม -> ตก whisper/mock
# STT_ENGINE=whisper
# GEMINI_STT_MODEL=gemini-2.5-flash        # โมเดลถอดเสียง (audio understanding)
# ตั้ง = ส่งไฟล์เสียงไปถอดที่ STT service บน server (ดู ../stt_server/)
# ปล่อยว่าง = ถอดในเครื่อง local เองด้วย faster-whisper (ตามค่า WHISPER_* ด้านล่าง)
STT_BASE_URL=http://<SERVER_IP>:8900
# STT_TIMEOUT=1800          # วินาที (คลิปยาวใช้เวลานาน)

# ---- WhisperX / faster-whisper (ใช้ตอนถอดในเครื่อง local เท่านั้น) ----
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu          # cuda ถ้ามี GPU

# ---- Obsidian vault (ทาง A: ชี้ไป vault เดิมที่มี standard work) ----
# ระบบจะเขียนลง subfolder meetings/ และ machines/ ภายใต้ path นี้
# ตัวอย่าง: D:\FactoryVault
VAULT_PATH=D:\FactoryVault

# ---- เสียงอ่านคำตอบ JARVIS (TTS) หน้า /ask ----
# TTS_ENGINE เลือกเสียง: windows(ค่าเริ่มต้น, offline) | edge(Neural ฟรี ออนไลน์) | gemini
#   gemini = ใช้ GEMINI_API_KEY ด้านบน; ล่ม -> ตก fallback เสียงเบราว์เซอร์
# TTS_ENGINE=edge
# -- edge-tts (ออนไลน์ ฟรี) --
# TTS_VOICE=th-TH-NiwatNeural   # ชายไทย (JARVIS) ; หญิง = th-TH-PremwadeeNeural
# TTS_RATE=+0%                  # ความเร็ว เช่น -5% ช้าลง, +10% เร็วขึ้น
# TTS_PITCH=+0Hz                # โทน เช่น -8Hz ทุ้มลงให้ดูเป็น AI ผู้ชาย
# -- Gemini TTS (คืน PCM ดิบ โค้ดห่อ WAV ให้; เสียงไทยต้องลองว่าดีพอไหม) --
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE=Charon       # 1 ใน ~30 เสียง เช่น Charon/Kore/Puck — ลองหาที่พูดไทยเพราะสุด
