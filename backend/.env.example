# ===== คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง =====
# คำสั่ง: copy .env.example .env   (Windows)
# (ตัวแปร optional ที่ code มี default อยู่แล้ว เช่น QWEN_*/WHISPER_*/EMBED_MODEL/RAG_* ไม่ต้องใส่)

# ---- Auth (login admin + JWT) — ไม่ตั้ง = login ไม่ได้ ----
# ห้ามใช้ชื่อ USERNAME เฉยๆ (Windows จองไว้) -> ใช้ ADMIN_USERNAME
# คนที่ 1: ADMIN_USERNAME/ADMIN_PASSWORD ; คนถัดไปเติมเลข ADMIN2_/ADMIN3_ ... ถึง ADMIN10_
# ไม่ตั้งรหัสเฉพาะตัว (ADMIN2_PASSWORD) -> ใช้ ADMIN_PASSWORD ร่วมกัน
ADMIN_PASSWORD=<ตั้งรหัสจริง>
ADMIN_USERNAME=<ชื่อคนที่1>
ADMIN2_USERNAME=<ชื่อคนที่2>
ADMIN3_USERNAME=<ชื่อคนที่3>
# JWT_SECRET: สุ่มยาวๆ เช่น  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<สุ่ม_hex_32ไบต์>

# ---- Azure OpenAI (LLM /api/ask เช่น gpt-5.4-mini) ----
# ดู endpoint/key ที่ Azure Portal > Azure OpenAI > Keys and Endpoint
# DEPLOYMENT = ชื่อ deployment ใน Azure (ไม่ใช่ชื่อโมเดล)
AZURE_OPENAI_ENDPOINT=https://<RESOURCE_NAME>.openai.azure.com
AZURE_OPENAI_API_KEY=<YOUR_AZURE_API_KEY>
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-54-mini

# ---- n8n proxy (ยิง GPT ผ่าน webhook n8n แทนเรียก Azure ตรง) ----
# n8n ถือ API key เอง -> key ไม่อยู่ในแอป ; workflow: backend/n8n/ask_javis.json
N8N_ASK_URL=http://<N8N_HOST>/webhook/ask_javis

# ---- STT/TTS engine ----
# STT_ENGINE: openai(gpt-4o-transcribe) | gemini | whisper
# TTS_ENGINE: openai(gpt-4o-mini-tts) | gemini | windows
STT_ENGINE=openai
TTS_ENGINE=openai

# ---- OpenAI Audio (TTS+STT ผ่าน Azure OpenAI resource เสียง) ----
# API_VERSION ไม่ตั้ง = ตกไปใช้ AZURE_OPENAI_API_VERSION ด้านบน
# DEPLOYMENT = ชื่อ deployment ใน Azure (ไม่ใช่ชื่อโมเดล)
OPENAI_AUDIO_ENDPOINT=https://<RESOURCE_NAME>.openai.azure.com
OPENAI_AUDIO_API_KEY=<KEY ของ resource เสียง>
OPENAI_TTS_DEPLOYMENT=gpt-4o-mini-tts
OPENAI_STT_DEPLOYMENT=gpt-4o-transcribe
OPENAI_TTS_VOICE=verse
OPENAI_STT_LANG=th

# ---- Gemini (ใช้ตอน STT_ENGINE/TTS_ENGINE = gemini) ----
GEMINI_API_KEY=<KEY_บริษัท>

# ---- Obsidian vault — ระบบเขียนลง subfolder meetings/ และ machines/ ----
# ตัวอย่าง: D:\FactoryVault
VAULT_PATH=D:\FactoryVault
