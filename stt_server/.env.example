# ===== STT service config (รันบน server) =====

# โมเดล faster-whisper
#   ตอนนี้ (CPU): small  — เร็วพอ แต่เสียงไทยประชุมยังมั่ว
#   พอมี GPU 12GB: เปลี่ยนเป็น large-v3
WHISPER_MODEL=small

# อุปกรณ์: cpu (ตอนนี้) | cuda (พอมี GPU)
#   โค้ดเลือก compute_type ให้อัตโนมัติ: cpu->int8, cuda->float16
WHISPER_DEVICE=cpu

# ภาษา: th | en | auto (ตรวจเอง)
WHISPER_LANG=th

# พอร์ตที่ service ฟัง (เปิด firewall inbound TCP พอร์ตนี้ด้วย)
STT_PORT=8900
